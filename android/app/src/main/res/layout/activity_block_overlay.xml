<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9F9F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- App Icon: Shows the ACTUAL blocked app icon -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_app_icon">

            <ImageView
                android:id="@+id/app_icon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                android:tint="#B0B3C0" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="36dp" />

        <!-- Title: "[App] is temporarily unavailable" -->
        <TextView
            android:id="@+id/block_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TikTok is temporarily unavailable"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#19202E"
            android:gravity="center" />

        <View
            android:layout_width="0dp"
            android:layout_height="8dp" />

        <!-- Subtitle / reason -->
        <TextView
            android:id="@+id/block_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This content is not suitable."
            android:textSize="15sp"
            android:textColor="#666D7D"
            android:gravity="center" />

        <View
            android:layout_width="0dp"
            android:layout_height="36dp" />

        <!-- Countdown timer -->
        <TextView
            android:id="@+id/block_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 : 00"
            android:textSize="52sp"
            android:textColor="#19202E"
            android:includeFontPadding="false"
            android:letterSpacing="0.08" />

        <View
            android:layout_width="0dp"
            android:layout_height="6dp" />

        <!-- "Available in" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available in"
            android:textSize="14sp"
            android:textColor="#666D7D" />

        <View
            android:layout_width="0dp"
            android:layout_height="24dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/block_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:max="60000"
            android:progress="60000"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- "Notify my parent" button -->
        <LinearLayout
            android:id="@+id/block_report_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_send"
                android:tint="#3B4657" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Notify my parent"
                android:textColor="#3B4657"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="14dp" />

        <!-- "Returns automatically at X" -->
        <TextView
            android:id="@+id/block_return_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Returns automatically at 10:40 PM"
            android:textSize="12sp"
            android:textColor="#858D9C"
            android:gravity="center" />

        <View
            android:layout_width="0dp"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
